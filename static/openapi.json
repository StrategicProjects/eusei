{
  "openapi": "3.0.3",
  "info": {
    "title": "eusei — API dos Web Services do SEI",
    "version": "0.5.3",
    "x-logo": {
      "url": "data:image/svg+xml;base64,",
      "altText": "eusei",
      "backgroundColor": "transparent"
    },
    "description": "API HTTP/JSON read-only sobre os Web Services SOAP do SEI (Sistema Eletrônico de Informações) do governo de Pernambuco. Espelha as consultas do pacote R `rsei`. Roda no servidor de aplicação (único com acesso liberado ao SEI) e é publicada via nginx.\n\n**Autenticação:** todas as rotas `/v1/*` exigem o cabeçalho `Authorization: Bearer <token>`.\n\n**Protocolos com barra:** consulte processos/documentos/blocos pela query string (`?protocolo=...`); a barra do número não sobrevive como `%2F` no path através do proxy.\n\n**Cache:** respostas **JSON** de `/v1/*` são cacheadas em memória (read-only) e trazem `X-Cache: HIT|MISS|STALE|PARTIAL` e `Cache-Control: private, max-age=<ttl>` + `Age` coerentes com o TTL da operação (listas ~6h; dados de processo ~30s). Em falha de infraestrutura do SEI, o último valor bom pode ser servido (`X-Cache: STALE`). Envie `Cache-Control: no-cache` para revalidar ou `no-store` para buscar fresco sem persistir (a resposta volta com `Cache-Control: no-store`). O endpoint SSE `/v1/andamentos/stream` é exceção: não carrega esses headers (é um fluxo de eventos), mas respeita `no-cache`/`no-store`."
  },
  "servers": [
    { "url": "/eusei", "description": "Produção (atrás do nginx, relativo ao host)" },
    { "url": "http://127.0.0.1:18088", "description": "Interno (servidor)" }
  ],
  "security": [{ "bearerAuth": [] }],
  "tags": [
    { "name": "saúde" },
    { "name": "consultas" },
    { "name": "andamentos" },
    { "name": "listas" },
    { "name": "sip" }
  ],
  "paths": {
    "/health": {
      "get": {
        "tags": ["saúde"],
        "summary": "Liveness (sem autenticação)",
        "security": [],
        "responses": { "200": { "description": "serviço no ar", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Health" } } } } }
      }
    },
    "/v1/procedimento": {
      "get": {
        "tags": ["consultas"],
        "summary": "Consulta um processo",
        "description": "Além de `dados` (campos originais do SEI: `ProcedimentosRelacionados`, `ProcedimentosAnexados`, `UnidadesProcedimentoAberto`, `AndamentoConclusao` etc.), a resposta inclui o campo derivado **`concluido`**: `true` se não há unidades com o processo aberto, `false` se há, `null` se indeterminado (quando `sin_retornar_unidades_procedimento_aberto=N`).",
        "parameters": [
          { "$ref": "#/components/parameters/Protocolo" },
          { "name": "sin_retornar_assuntos", "in": "query", "schema": { "$ref": "#/components/schemas/SinFlag" } },
          { "name": "sin_retornar_interessados", "in": "query", "schema": { "$ref": "#/components/schemas/SinFlag" } },
          { "name": "sin_retornar_observacoes", "in": "query", "schema": { "$ref": "#/components/schemas/SinFlag" } },
          { "name": "sin_retornar_andamento_geracao", "in": "query", "schema": { "$ref": "#/components/schemas/SinFlag" } },
          { "name": "sin_retornar_andamento_conclusao", "in": "query", "schema": { "$ref": "#/components/schemas/SinFlag" } },
          { "name": "sin_retornar_ultimo_andamento", "in": "query", "schema": { "$ref": "#/components/schemas/SinFlag" } },
          { "name": "sin_retornar_unidades_procedimento_aberto", "in": "query", "schema": { "$ref": "#/components/schemas/SinFlag" } },
          { "name": "sin_retornar_procedimentos_relacionados", "in": "query", "schema": { "$ref": "#/components/schemas/SinFlag" } },
          { "name": "sin_retornar_procedimentos_anexados", "in": "query", "schema": { "$ref": "#/components/schemas/SinFlag" } }
        ],
        "responses": {
          "200": { "$ref": "#/components/responses/Processo" },
          "400": { "$ref": "#/components/responses/Erro" },
          "401": { "$ref": "#/components/responses/Erro" }
        }
      }
    },
    "/v1/procedimentos": {
      "get": {
        "tags": ["consultas"],
        "summary": "Consulta vários processos (lote)",
        "parameters": [{ "name": "protocolos", "in": "query", "required": true, "description": "Protocolos separados por vírgula", "schema": { "type": "string" }, "example": "0011108545.000056/2022-49,0030600043.002462/2024-05" }],
        "responses": { "200": { "$ref": "#/components/responses/Lote" }, "400": { "$ref": "#/components/responses/Erro" }, "401": { "$ref": "#/components/responses/Erro" } }
      }
    },
    "/v1/procedimento-individual": {
      "get": {
        "tags": ["consultas"],
        "summary": "Processo individual mais recente do usuário",
        "parameters": [
          { "name": "id_orgao_procedimento", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "id_tipo_procedimento", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "id_orgao_usuario", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "sigla_usuario", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "$ref": "#/components/responses/Dados" }, "400": { "$ref": "#/components/responses/Erro" }, "401": { "$ref": "#/components/responses/Erro" } }
      }
    },
    "/v1/documento": {
      "get": {
        "tags": ["consultas"],
        "summary": "Consulta um documento",
        "parameters": [
          { "$ref": "#/components/parameters/Protocolo" },
          { "name": "sin_retornar_andamento_geracao", "in": "query", "schema": { "$ref": "#/components/schemas/SinFlag" } },
          { "name": "sin_retornar_assinaturas", "in": "query", "schema": { "$ref": "#/components/schemas/SinFlag" } },
          { "name": "sin_retornar_publicacao", "in": "query", "schema": { "$ref": "#/components/schemas/SinFlag" } },
          { "name": "sin_retornar_campos", "in": "query", "schema": { "$ref": "#/components/schemas/SinFlag" } }
        ],
        "responses": { "200": { "$ref": "#/components/responses/Dados" }, "400": { "$ref": "#/components/responses/Erro" }, "401": { "$ref": "#/components/responses/Erro" } }
      }
    },
    "/v1/documentos": {
      "get": {
        "tags": ["consultas"],
        "summary": "Consulta vários documentos (lote)",
        "parameters": [{ "name": "protocolos", "in": "query", "required": true, "description": "Números de documento separados por vírgula", "schema": { "type": "string" } }],
        "responses": { "200": { "$ref": "#/components/responses/Lote" }, "400": { "$ref": "#/components/responses/Erro" }, "401": { "$ref": "#/components/responses/Erro" } }
      }
    },
    "/v1/publicacao": {
      "get": {
        "tags": ["consultas"],
        "summary": "Consulta publicação",
        "description": "Informe ao menos um de: id_publicacao, id_documento, protocolo_documento.",
        "parameters": [
          { "name": "id_publicacao", "in": "query", "schema": { "type": "string" } },
          { "name": "id_documento", "in": "query", "schema": { "type": "string" } },
          { "name": "protocolo_documento", "in": "query", "schema": { "type": "string" } },
          { "name": "sin_retornar_andamento", "in": "query", "schema": { "$ref": "#/components/schemas/SinFlag" } },
          { "name": "sin_retornar_assinaturas", "in": "query", "schema": { "$ref": "#/components/schemas/SinFlag" } }
        ],
        "responses": { "200": { "$ref": "#/components/responses/Dados" }, "400": { "$ref": "#/components/responses/Erro" }, "401": { "$ref": "#/components/responses/Erro" } }
      }
    },
    "/v1/bloco": {
      "get": {
        "tags": ["consultas"],
        "summary": "Consulta um bloco",
        "parameters": [
          { "name": "id", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "sin_retornar_protocolos", "in": "query", "schema": { "$ref": "#/components/schemas/SinFlag" }, "description": "Padrão N" }
        ],
        "responses": { "200": { "$ref": "#/components/responses/Dados" }, "400": { "$ref": "#/components/responses/Erro" }, "401": { "$ref": "#/components/responses/Erro" } }
      }
    },
    "/v1/andamentos": {
      "get": {
        "tags": ["andamentos"],
        "summary": "Linha do tempo (andamentos) de um processo",
        "description": "Sem filtros, usa as tarefas 1..200 (linha do tempo completa) e ordena por data/hora.\n\n**Processos grandes:** a consulta é fatiada em lotes de tarefas, executados em paralelo e mesclados (deduplicados por `IdAndamento`, ordenados por data/hora) — evita o HTTP 504 do gateway do SEI em processos enormes. A resposta inclui um bloco `resumo` (`lotes`, `lotes_com_dados`, `registros`, `parciais`); `parciais: true` indica que algum lote falhou e a linha do tempo pode estar incompleta. Para acompanhar o avanço ao vivo, use `/v1/andamentos/stream` (SSE).",
        "parameters": [
          { "$ref": "#/components/parameters/Protocolo" },
          { "name": "tarefas", "in": "query", "description": "IDs de tarefa separados por vírgula", "schema": { "type": "string" } },
          { "name": "andamentos", "in": "query", "description": "IDs de andamento separados por vírgula", "schema": { "type": "string" } },
          { "name": "tarefas_modulos", "in": "query", "schema": { "type": "string" } },
          { "name": "sin_retornar_atributos", "in": "query", "schema": { "$ref": "#/components/schemas/SinFlag" } },
          { "name": "ordenar", "in": "query", "schema": { "type": "boolean", "default": true } }
        ],
        "responses": { "200": { "$ref": "#/components/responses/ComResumo" }, "400": { "$ref": "#/components/responses/Erro" }, "401": { "$ref": "#/components/responses/Erro" } }
      }
    },
    "/v1/andamentos/stream": {
      "get": {
        "tags": ["andamentos"],
        "summary": "Linha do tempo via SSE (progresso ao vivo)",
        "description": "Mesma consulta de `/v1/andamentos`, porém em `text/event-stream`. Emite um evento `progresso` a cada lote concluído (`lotes_concluidos`, `total_lotes`, `registros_ate_agora`, `parciais`) e, ao final, um evento `concluido` com `{ ok, dados, resumo }`. Um SOAP Fault encerra com um evento `erro`. Útil para exibir uma barra de progresso ao usuário em processos grandes.",
        "parameters": [
          { "$ref": "#/components/parameters/Protocolo" },
          { "name": "tarefas", "in": "query", "description": "IDs de tarefa separados por vírgula", "schema": { "type": "string" } },
          { "name": "andamentos", "in": "query", "description": "IDs de andamento separados por vírgula", "schema": { "type": "string" } },
          { "name": "tarefas_modulos", "in": "query", "schema": { "type": "string" } },
          { "name": "sin_retornar_atributos", "in": "query", "schema": { "$ref": "#/components/schemas/SinFlag" } },
          { "name": "ordenar", "in": "query", "schema": { "type": "boolean", "default": true } }
        ],
        "responses": {
          "200": { "description": "Stream SSE de eventos `progresso`/`concluido`/`erro`.", "content": { "text/event-stream": { "schema": { "type": "string" } } } },
          "400": { "$ref": "#/components/responses/Erro" },
          "401": { "$ref": "#/components/responses/Erro" }
        }
      }
    },
    "/v1/documentos-processo": {
      "get": {
        "tags": ["andamentos"],
        "summary": "Documentos de um processo (heurística da timeline)",
        "description": "O SEI não expõe isso nativamente; os números de documento são extraídos das descrições dos andamentos.",
        "parameters": [{ "$ref": "#/components/parameters/Protocolo" }],
        "responses": { "200": { "$ref": "#/components/responses/ComResumo" }, "400": { "$ref": "#/components/responses/Erro" }, "401": { "$ref": "#/components/responses/Erro" } }
      }
    },
    "/v1/publicacoes-processo": {
      "get": {
        "tags": ["andamentos"],
        "summary": "Publicações de um processo (heurística da timeline)",
        "description": "Descobre os documentos do processo e consulta a publicação de cada um, mantendo só os que possuem publicação. Endpoint pesado: faz uma consulta por documento (paralelizadas) — pode levar dezenas de segundos em processos grandes.",
        "parameters": [{ "$ref": "#/components/parameters/Protocolo" }],
        "responses": { "200": { "$ref": "#/components/responses/ComResumo" }, "400": { "$ref": "#/components/responses/Erro" }, "401": { "$ref": "#/components/responses/Erro" } }
      }
    },
    "/v1/permissao": {
      "get": {
        "tags": ["sip"],
        "summary": "Lista permissões no SIP (Sistema de Permissões)",
        "description": "Usa o SIP (endpoint/credenciais próprios). Requer SEI_SIP_CHAVE_ACESSO e SEI_SIP_ID_SISTEMA no servidor; sem isso, retorna 400.",
        "parameters": [
          { "name": "id_orgao_usuario", "in": "query", "schema": { "type": "string" } },
          { "name": "id_usuario", "in": "query", "schema": { "type": "string" } },
          { "name": "id_origem_usuario", "in": "query", "schema": { "type": "string" } },
          { "name": "id_orgao_unidade", "in": "query", "schema": { "type": "string" } },
          { "name": "id_unidade", "in": "query", "schema": { "type": "string" } },
          { "name": "id_origem_unidade", "in": "query", "schema": { "type": "string" } },
          { "name": "id_perfil", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": { "200": { "$ref": "#/components/responses/Dados" }, "400": { "$ref": "#/components/responses/Erro" }, "401": { "$ref": "#/components/responses/Erro" } }
      }
    },
    "/v1/paises": { "get": { "tags": ["listas"], "summary": "Lista países", "responses": { "200": { "$ref": "#/components/responses/Dados" }, "default": { "$ref": "#/components/responses/Erro" } } } },
    "/v1/estados": { "get": { "tags": ["listas"], "summary": "Lista estados (UF)", "parameters": [{ "name": "id_pais", "in": "query", "schema": { "type": "string" } }], "responses": { "200": { "$ref": "#/components/responses/Dados" }, "default": { "$ref": "#/components/responses/Erro" } } } },
    "/v1/cidades": { "get": { "tags": ["listas"], "summary": "Lista cidades", "parameters": [{ "name": "id_pais", "in": "query", "schema": { "type": "string" } }, { "name": "id_estado", "in": "query", "schema": { "type": "string" } }], "responses": { "200": { "$ref": "#/components/responses/Dados" }, "default": { "$ref": "#/components/responses/Erro" } } } },
    "/v1/unidades": { "get": { "tags": ["listas"], "summary": "Lista unidades", "parameters": [{ "name": "id_tipo_procedimento", "in": "query", "schema": { "type": "string" } }, { "name": "id_serie", "in": "query", "schema": { "type": "string" } }], "responses": { "200": { "$ref": "#/components/responses/Dados" }, "default": { "$ref": "#/components/responses/Erro" } } } },
    "/v1/series": { "get": { "tags": ["listas"], "summary": "Lista séries (tipos de documento)", "parameters": [{ "name": "id_unidade", "in": "query", "schema": { "type": "string" } }, { "name": "id_tipo_procedimento", "in": "query", "schema": { "type": "string" } }], "responses": { "200": { "$ref": "#/components/responses/Dados" }, "default": { "$ref": "#/components/responses/Erro" } } } },
    "/v1/tipos-procedimento": { "get": { "tags": ["listas"], "summary": "Lista tipos de processo", "parameters": [{ "name": "id_unidade", "in": "query", "schema": { "type": "string" } }, { "name": "id_serie", "in": "query", "schema": { "type": "string" } }], "responses": { "200": { "$ref": "#/components/responses/Dados" }, "default": { "$ref": "#/components/responses/Erro" } } } },
    "/v1/tipos-procedimento-ouvidoria": { "get": { "tags": ["listas"], "summary": "Lista tipos de processo de ouvidoria", "responses": { "200": { "$ref": "#/components/responses/Dados" }, "default": { "$ref": "#/components/responses/Erro" } } } },
    "/v1/tipos-conferencia": { "get": { "tags": ["listas"], "summary": "Lista tipos de conferência", "parameters": [{ "name": "id_unidade", "in": "query", "schema": { "type": "string" } }], "responses": { "200": { "$ref": "#/components/responses/Dados" }, "default": { "$ref": "#/components/responses/Erro" } } } },
    "/v1/cargos": { "get": { "tags": ["listas"], "summary": "Lista cargos", "parameters": [{ "name": "id_cargo", "in": "query", "schema": { "type": "string" } }], "responses": { "200": { "$ref": "#/components/responses/Dados" }, "default": { "$ref": "#/components/responses/Erro" } } } },
    "/v1/hipoteses-legais": { "get": { "tags": ["listas"], "summary": "Lista hipóteses legais", "parameters": [{ "name": "nivel_acesso", "in": "query", "schema": { "type": "string", "enum": ["1", "2"] } }], "responses": { "200": { "$ref": "#/components/responses/Dados" }, "default": { "$ref": "#/components/responses/Erro" } } } },
    "/v1/extensoes-permitidas": { "get": { "tags": ["listas"], "summary": "Lista extensões permitidas", "parameters": [{ "name": "id_arquivo_extensao", "in": "query", "schema": { "type": "string" } }], "responses": { "200": { "$ref": "#/components/responses/Dados" }, "default": { "$ref": "#/components/responses/Erro" } } } },
    "/v1/marcadores-unidade": { "get": { "tags": ["listas"], "summary": "Lista marcadores da unidade", "responses": { "200": { "$ref": "#/components/responses/Dados" }, "default": { "$ref": "#/components/responses/Erro" } } } },
    "/v1/usuarios": { "get": { "tags": ["listas"], "summary": "Lista usuários da unidade", "parameters": [{ "name": "id_usuario", "in": "query", "schema": { "type": "string" } }], "responses": { "200": { "$ref": "#/components/responses/Dados" }, "default": { "$ref": "#/components/responses/Erro" } } } },
    "/v1/feriados": { "get": { "tags": ["listas"], "summary": "Lista feriados", "parameters": [{ "name": "id_orgao", "in": "query", "schema": { "type": "string" } }, { "name": "data_inicial", "in": "query", "schema": { "type": "string" } }, { "name": "data_final", "in": "query", "schema": { "type": "string" } }], "responses": { "200": { "$ref": "#/components/responses/Dados" }, "default": { "$ref": "#/components/responses/Erro" } } } },
    "/v1/contatos": { "get": { "tags": ["listas"], "summary": "Lista contatos (paginado)", "parameters": [{ "name": "id_tipo_contato", "in": "query", "schema": { "type": "string" } }, { "name": "pagina_registros", "in": "query", "schema": { "type": "string" } }, { "name": "pagina_atual", "in": "query", "schema": { "type": "string" } }, { "name": "sigla", "in": "query", "schema": { "type": "string" } }, { "name": "nome", "in": "query", "schema": { "type": "string" } }, { "name": "cpf", "in": "query", "schema": { "type": "string" } }, { "name": "cnpj", "in": "query", "schema": { "type": "string" } }, { "name": "matricula", "in": "query", "schema": { "type": "string" } }], "responses": { "200": { "$ref": "#/components/responses/Dados" }, "default": { "$ref": "#/components/responses/Erro" } } } }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": { "type": "http", "scheme": "bearer" }
    },
    "parameters": {
      "Protocolo": { "name": "protocolo", "in": "query", "required": true, "description": "Número do processo/documento visível ao usuário", "schema": { "type": "string" }, "example": "0011108545.000056/2022-49" }
    },
    "schemas": {
      "SinFlag": { "type": "string", "enum": ["S", "N"], "default": "S" },
      "Health": { "type": "object", "properties": { "ok": { "type": "boolean" }, "service": { "type": "string" }, "version": { "type": "string" } } },
      "Dados": { "type": "object", "properties": { "ok": { "type": "boolean", "example": true }, "dados": { "description": "Objeto ou array com os dados do SEI (nomes originais do SEI; xsi:nil vira null)." } } },
      "Resumo": { "type": "object", "description": "Resumo do fatiamento em lotes da timeline.", "properties": { "lotes": { "type": "integer" }, "lotes_com_dados": { "type": "integer" }, "registros": { "type": "integer" }, "parciais": { "type": "boolean", "description": "true = algum lote falhou; a timeline pode estar incompleta." }, "tarefas_por_lote": { "type": "integer" } } },
      "Processo": { "type": "object", "properties": { "ok": { "type": "boolean", "example": true }, "dados": { "description": "Processo (nomes originais do SEI: ProcedimentosRelacionados, ProcedimentosAnexados, UnidadesProcedimentoAberto, AndamentoConclusao etc.)." }, "concluido": { "type": "boolean", "nullable": true, "description": "Derivado: true se sem unidades abertas; false se há; null se não solicitado (sin_retornar_unidades_procedimento_aberto=N)." } } },
      "ComResumo": { "type": "object", "properties": { "ok": { "type": "boolean", "example": true }, "dados": { "description": "Array derivado da timeline (andamentos, documentos ou publicações)." }, "resumo": { "$ref": "#/components/schemas/Resumo" } } },
      "Lote": { "type": "object", "properties": { "ok": { "type": "boolean" }, "itens": { "type": "array", "items": { "type": "object", "properties": { "protocolo": { "type": "string" }, "dados": {}, "concluido": { "type": "boolean", "nullable": true, "description": "Presente no lote de processos (/v1/procedimentos); ausente em documentos." }, "erro": { "type": "string", "nullable": true } } } } } },
      "Erro": { "type": "object", "properties": { "ok": { "type": "boolean", "example": false }, "codigo": { "type": "string", "description": "Código estável legível por máquina.", "enum": ["nao_autorizado", "parametro_invalido", "sei_indisponivel", "sei_timeout", "sei_erro_http", "sei_fault", "resposta_invalida"] }, "erro": { "type": "string" }, "detalhe": { "type": "string", "nullable": true } } }
    },
    "responses": {
      "Dados": { "description": "Sucesso", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Dados" } } } },
      "Processo": { "description": "Processo + estado de conclusão derivado", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Processo" } } } },
      "ComResumo": { "description": "Lista derivada da timeline + resumo dos lotes", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ComResumo" } } } },
      "Lote": { "description": "Resultado em lote", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Lote" } } } },
      "Erro": { "description": "Erro", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Erro" } } } }
    }
  }
}
