# eusei — exemplo de configuração. Copie para `.env` (dev) ou para
# /etc/eusei.env (produção, chmod 600). NÃO comitar o arquivo real.

# porta interna (escolha uma livre; o nginx faz proxy para ela)
EUSEI_BIND=127.0.0.1:18088
# Tokens Bearer aceitos (separados por vírgula). DEVE ser um valor real:
# o serviço recusa subir com tokens placeholder ("TROQUE..."). O deploy
# (02-deploy-sudo.sh) gera um token aleatório automaticamente no install.
EUSEI_TOKENS=troque-este-token

# Acesso ao SEI (produção, read-only)
SEI_URL=https://sei.pe.gov.br/sei/ws/SeiWS.php
SEI_SIGLA_SISTEMA=HORTENSIAS
SEI_IDENTIFICACAO_SERVICO=COLOQUE_A_CHAVE_DE_ACESSO_AQUI
SEI_ID_UNIDADE=
SEI_TIMEOUT_SECS=60
# Linha do tempo de processos grandes: a consulta listarAndamentos é fatiada em
# lotes de tarefas (evita o HTTP 504 do gateway do SEI). LOTE = tarefas por
# chamada (menor = mais leve/seguro); CONC = lotes em paralelo (menor = menos
# pressão sobre o SEI). Defaults afinados contra o SEI-PE; ajuste se o seu SEI
# tiver janela de timeout diferente.
SEI_ANDAMENTOS_LOTE=8
SEI_ANDAMENTOS_CONC=3

# Cache em memória das respostas do SEI (read-only). Reduz latência e protege o
# SEI (chamadas idênticas concorrentes coalescem). EUSEI_CACHE=off desliga tudo.
# TTL por classe: estático = listas quase-fixas (países, séries, tipos…); semi =
# usuários/contatos/permissões; dinâmico = consultas/andamentos (curto, p/ frescor).
# Clientes podem forçar dados frescos com o header `Cache-Control: no-cache`.
EUSEI_CACHE=on
EUSEI_CACHE_MAX_MB=256
EUSEI_CACHE_TTL_ESTATICO_SECS=21600
EUSEI_CACHE_TTL_SEMI_SECS=600
EUSEI_CACHE_TTL_DINAMICO_SECS=30

# SIP (Sistema de Permissões) — opcional; necessário só para /v1/permissao
SEI_SIP_URL=https://sei.pe.gov.br/sip/controlador_ws.php?servico=sip
SEI_SIP_CHAVE_ACESSO=
SEI_SIP_ID_SISTEMA=

RUST_LOG=eusei=info,tower_http=info
